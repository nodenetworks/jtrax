<?xml version="1.0" encoding="utf-8"?>
<form>
	<fieldset>
		<field
			name="id"
			type="hidden"
		/>
		
		<field
			name="code"
			type="text"
			label="COM_JTRAX_LABEL_CODE"
			description="COM_JTRAX_DESCRIPTION_CODE"
			size="10"
			class="inputbox"
			default=""
		/>
		
		<field
			name="catid"
			type="category"
			extension="com_helloworld"
			class="inputbox"
			default=""
			label="COM_JTRAX_JTRAX_FIELD_CATID_LABEL"
			description="COM_JTRAX_JTRAX_FIELD_CATID_DESC"
			required="true"
		>
			<option value="0">JOPTION_SELECT_CATEGORY</option>
		</field>
		
		<field
			name="status"
			type="text"
			label="COM_JTRAX_LABEL_STATUS"
			description="COM_JTRAX_DESCRIPTION_STATUS"
			size="40"
			class="inputbox"
			default=""
		/>
		
		<field
			name="datetime"
			type="calendar"
			label="COM_JTRAX_LABEL_DATE"
			class="inputbox"
			default="NOW"
		/>
		
		<field
		name="published"
		type="list"
		label="JSTATUS"
		description="JFIELD_PUBLISHED_DESC"
		class="chzn-color-state"
		default="1"
		size="1"
		>
		<option value="1">JPUBLISHED</option>
		<option value="0">JUNPUBLISHED</option>
		<option value="2">JARCHIVED</option>
		<option value="-2">JTRASHED</option>
		</field>

	<field
		name="checked_out"
		type="hidden"
		filter="unset"
	/>

	<field
		name="checked_out_time"
		type="hidden"
		filter="unset"
	/>
	
	</fieldset>
</form>